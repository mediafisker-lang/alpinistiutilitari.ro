generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerificationStatus {
  pending
  verified
  hidden
}

enum LeadRequestStatus {
  noua
  in_analiza
  executanti_contactati
  client_contactat
  ofertare_in_curs
  finalizata
  inchisa
  respinsa
}

enum LeadUrgency {
  normal
  urgent
}

enum CompanySourceType {
  manual
  google_places
  claimed
}

enum ImportRunStatus {
  pending
  running
  completed
  failed
}

enum AdminRole {
  admin
  editor
}

model County {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  shortCode String?   @unique
  intro     String?
  introText String?
  seoTitle  String?
  seoDescription String?
  faqJson   Json?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  cities    City[]
  companies Company[]
  coverage  CompanyCoverage[]
  leadRequests LeadRequest[]
  faqs      FAQ[]
  importRuns CompanyImportRun[]

  @@index([slug])
  @@index([isActive])
}

model City {
  id        String    @id @default(cuid())
  countyId  String
  name      String
  slug      String    @unique
  intro     String?
  introText String?
  seoTitle  String?
  seoDescription String?
  population Int?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  county    County    @relation(fields: [countyId], references: [id], onDelete: Cascade)
  companies Company[]
  coverage  CompanyCoverage[]
  leadRequests LeadRequest[]
  faqs      FAQ[]
  importRuns CompanyImportRun[]

  @@index([countyId])
  @@index([slug])
  @@index([isActive])
  @@unique([countyId, name])
}

model Service {
  id          String           @id @default(cuid())
  name        String           @unique
  slug        String           @unique
  category    String?
  shortName   String?
  shortDescription String
  longDescription String
  seoTitle    String?
  seoDescription String?
  seoIntro    String?
  icon        String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  companies   CompanyService[]
  articles    ArticleService[]
  faqs        FAQ[]
  leadRequests LeadRequest[]
  importMappings GooglePlaceCategoryMap[]

  @@index([slug])
  @@index([isActive])
}

model Company {
  id                 String             @id @default(cuid())
  countyId           String
  cityId             String
  name               String
  slug               String             @unique
  legalName          String?
  cui                String?            @unique
  registrationNumber String?
  descriptionShort   String
  descriptionLong    String
  logoUrl            String?
  coverImageUrl      String?
  website            String?
  email              String?
  phone              String?
  whatsapp           String?
  address            String?
  latitude           Float?
  longitude          Float?
  galleryJson        Json?
  sourceType         CompanySourceType @default(manual)
  source             String?
  externalPlaceId    String?           @unique
  googleMapsUrl      String?
  ratingValue        Float?
  ratingCount        Int?
  openingHoursJson   Json?
  lastSyncedAt       DateTime?
  manuallyEditedAt   DateTime?
  foundedYear        Int?
  isVerified         Boolean            @default(false)
  verificationStatus VerificationStatus @default(pending)
  isFeatured         Boolean            @default(false)
  isActive           Boolean            @default(true)
  isPublished        Boolean            @default(true)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  county             County             @relation(fields: [countyId], references: [id], onDelete: Restrict)
  city               City               @relation(fields: [cityId], references: [id], onDelete: Restrict)
  services           CompanyService[]
  coverage           CompanyCoverage[]
  leadRequests       LeadRequest[]
  leadSelections     LeadCompanySelection[]
  importEvents       CompanyImportEvent[]

  @@index([countyId])
  @@index([cityId])
  @@index([slug])
  @@index([isVerified])
  @@index([isActive])
  @@index([verificationStatus])
  @@index([isPublished])
  @@index([externalPlaceId])
  @@index([countyId, isPublished, isActive])
  @@index([cityId, isPublished, isActive])
}

model CompanyService {
  id        String   @id @default(cuid())
  companyId String
  serviceId String
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([companyId, serviceId])
  @@index([companyId])
  @@index([serviceId])
  @@index([serviceId, companyId])
}

model CompanyCoverage {
  id        String   @id @default(cuid())
  companyId String
  countyId  String?
  cityId    String?
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  county    County?  @relation(fields: [countyId], references: [id], onDelete: SetNull)
  city      City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([countyId])
  @@index([cityId])
  @@index([countyId, cityId])
}

model LeadRequest {
  id         String     @id @default(cuid())
  companyId  String?
  fullName   String
  phone      String
  email      String?
  countyId   String?
  countyText String?
  cityId     String?
  cityText   String?
  address    String
  serviceId  String?
  serviceText String?
  urgency    LeadUrgency @default(normal)
  description String
  gdprAccepted Boolean
  attachmentsJson Json?
  status     LeadRequestStatus @default(noua)
  clientContacted Boolean @default(false)
  executantsContacted Boolean @default(false)
  resultSummary String?
  sourcePage String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  company    Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  county     County?    @relation(fields: [countyId], references: [id], onDelete: SetNull)
  city       City?      @relation(fields: [cityId], references: [id], onDelete: SetNull)
  service    Service?   @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  images     LeadRequestImage[]
  notes      LeadRequestNote[]
  events     LeadRequestEvent[]
  selections LeadCompanySelection[]

  @@index([companyId])
  @@index([status])
  @@index([countyId])
  @@index([cityId])
  @@index([serviceId])
  @@index([countyId, serviceId, status])
  @@index([cityId, serviceId, status])
}

model LeadRequestImage {
  id            String      @id @default(cuid())
  leadRequestId String
  fileUrl       String
  fileName      String
  createdAt     DateTime    @default(now())
  leadRequest   LeadRequest @relation(fields: [leadRequestId], references: [id], onDelete: Cascade)

  @@index([leadRequestId])
}

model LeadCompanySelection {
  id            String      @id @default(cuid())
  leadRequestId String
  companyId     String
  createdAt     DateTime    @default(now())
  leadRequest   LeadRequest @relation(fields: [leadRequestId], references: [id], onDelete: Cascade)
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([leadRequestId, companyId])
  @@index([leadRequestId])
  @@index([companyId])
}

model LeadRequestNote {
  id            String      @id @default(cuid())
  leadRequestId String
  adminUserId   String
  note          String
  createdAt     DateTime    @default(now())
  leadRequest   LeadRequest @relation(fields: [leadRequestId], references: [id], onDelete: Cascade)
  adminUser     AdminUser   @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([leadRequestId])
  @@index([adminUserId])
}

model LeadRequestEvent {
  id            String      @id @default(cuid())
  leadRequestId String
  type          String
  payloadJson   Json?
  createdAt     DateTime    @default(now())
  leadRequest   LeadRequest @relation(fields: [leadRequestId], references: [id], onDelete: Cascade)

  @@index([leadRequestId])
}

model Article {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  excerpt     String
  content     String
  coverImageUrl String?
  seoTitle    String?
  seoDescription String?
  publishedAt DateTime         @default(now())
  isPublished Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  services    ArticleService[]
  faqs        FAQ[]

  @@index([slug])
  @@index([publishedAt])
}

model ArticleService {
  id        String   @id @default(cuid())
  articleId String
  serviceId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([articleId, serviceId])
}

model FAQ {
  id         String   @id @default(cuid())
  pageType   String?
  pageRefId  String?
  question   String
  answer     String
  sortOrder  Int      @default(0)
  countyId   String?
  cityId     String?
  serviceId  String?
  articleId  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  county     County?  @relation(fields: [countyId], references: [id], onDelete: SetNull)
  city       City?    @relation(fields: [cityId], references: [id], onDelete: SetNull)
  service    Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  article    Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@index([pageType, pageRefId])
  @@index([countyId])
  @@index([cityId])
  @@index([serviceId])
  @@index([articleId])
}

model CompanyImportRun {
  id           String          @id @default(cuid())
  source       String
  query        String?
  countyId     String?
  cityId       String?
  totalFound   Int             @default(0)
  totalImported Int            @default(0)
  totalUpdated Int             @default(0)
  startedAt    DateTime        @default(now())
  finishedAt   DateTime?
  status       ImportRunStatus @default(pending)
  logJson      Json?
  county       County?         @relation(fields: [countyId], references: [id], onDelete: SetNull)
  city         City?           @relation(fields: [cityId], references: [id], onDelete: SetNull)
  events       CompanyImportEvent[]

  @@index([countyId])
  @@index([cityId])
}

model CompanyImportEvent {
  id           String           @id @default(cuid())
  importRunId  String
  companyId    String?
  externalId   String?
  status       String
  payloadJson  Json?
  createdAt    DateTime         @default(now())
  importRun    CompanyImportRun @relation(fields: [importRunId], references: [id], onDelete: Cascade)
  company      Company?         @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([importRunId])
  @@index([companyId])
}

model GooglePlaceCategoryMap {
  id          String   @id @default(cuid())
  placeType   String   @unique
  serviceId   String
  confidence  Float    @default(0.5)
  service     Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

model AdminUser {
  id           String            @id @default(cuid())
  email        String            @unique
  passwordHash String
  role         AdminRole         @default(admin)
  createdAt    DateTime          @default(now())
  sessions     AdminSession[]
  notes        LeadRequestNote[]
}

model AdminSession {
  id          String    @id @default(cuid())
  adminUserId String
  token       String    @unique
  expiresAt   DateTime
  createdAt   DateTime  @default(now())
  adminUser   AdminUser @relation(fields: [adminUserId], references: [id], onDelete: Cascade)

  @@index([adminUserId])
  @@index([expiresAt])
}
